{
  "openapi": "3.0.0",
  "info": {
    "title": "Rolls API",
    "version": "1.0.0",
    "description": "OpenAPI spec generated from Next.js route handlers."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local dev (API base)"
    },
    {
      "url": "https://rolls.yannick.computer/api",
      "description": "Production"
    }
  ],
  "routerType": "app",
  "apiDir": "app/api",
  "schemaType": "typescript",
  "schemaDir": ["app/api/_schemas"],
  "outputFile": "openapi.json",
  "outputDir": "./public",
  "docsUrl": "/api-docs",
  "includeOpenApiRoutes": true,
  "ignoreRoutes": [
    "/api/icon",
    "/api/apple-touch-icon"
  ],
  "debug": false
}
