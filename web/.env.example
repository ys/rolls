# Postgres connection string (Heroku Postgres or any direct PG connection)
DATABASE_URL=postgres://...

# API key for CLI tools (rolls push / rolls backup)
# Must match web_app_api_key in ~/.config/rolls/config.yml
API_KEY=change-me

# Optional: protect the web UI with a password (leave empty to disable)
WEB_PASSWORD=

# Cloudflare R2 for contact sheet storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
