{
  "name": "Rolls",
  "description": "Film photography roll tracker",
  "repository": "https://github.com/ys/rolls",
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0",
      "as": "DATABASE"
    }
  ],
  "buildpacks": [
    {
      "url": "heroku/ruby"
    }
  ],
  "env": {
    "RAILS_ENV": {
      "value": "production"
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens",
      "generator": "secret"
    },
    "WEBAUTHN_RP_NAME": {
      "description": "WebAuthn Relying Party name",
      "value": "Rolls",
      "required": false
    },
    "WEBAUTHN_RP_ID": {
      "description": "WebAuthn Relying Party ID (set to review app domain)",
      "required": false
    },
    "WEBAUTHN_ORIGIN": {
      "description": "WebAuthn origin (set to review app URL)",
      "required": false
    },
    "R2_ACCOUNT_ID": {
      "description": "Cloudflare R2 account ID",
      "required": false
    },
    "R2_ACCESS_KEY_ID": {
      "description": "Cloudflare R2 access key",
      "required": false
    },
    "R2_SECRET_ACCESS_KEY": {
      "description": "Cloudflare R2 secret key",
      "required": false
    },
    "R2_BUCKET": {
      "description": "Cloudflare R2 bucket name",
      "value": "rolls-staging",
      "required": false
    },
    "R2_PUBLIC_URL": {
      "description": "Cloudflare R2 public URL",
      "required": false
    },
    "MAILJET_API_KEY": {
      "description": "Mailjet API key (optional)",
      "required": false
    },
    "MAILJET_SECRET_KEY": {
      "description": "Mailjet secret key (optional)",
      "required": false
    },
    "MAILJET_FROM_EMAIL": {
      "description": "From email address",
      "value": "noreply@rolls.yannick.computer",
      "required": false
    },
    "MAILJET_FROM_NAME": {
      "description": "From name",
      "value": "Rolls",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "scripts": {
    "postdeploy": "bundle exec rails db:migrate"
  }
}
