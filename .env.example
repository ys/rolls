# ─── Quick local dev setup ────────────────────────────────────────────────
# Run:  bash scripts/setup.sh
# This creates .env.local, creates the local DB, and runs migrations.
# ─────────────────────────────────────────────────────────────────────────

# Postgres — use rolls_dev for local, DATABASE_URL on Heroku
DATABASE_URL=postgres://localhost/rolls_dev

# Authentication — WebAuthn (required for build/runtime)
JWT_SECRET=change-me-use-random-secret
WEBAUTHN_RP_NAME=Rolls
# Local dev: localhost / http://localhost:3000
# Production: yourdomain.com / https://yourdomain.com
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# API key for CLI tools (rolls push / rolls pull)
# Must match web_app_api_key in ~/.config/rolls/config.yml
API_KEY=change-me

# Optional: protect the web UI with a password (leave empty to disable)
WEB_PASSWORD=

# Cloudflare R2 for contact sheet storage (optional for local dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Base URL of this app
APP_URL=http://localhost:3000

# Redis (optional — rate limiting disabled when empty)
REDIS_URL=
