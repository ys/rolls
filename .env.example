# Postgres connection string (Heroku Postgres or any direct PG connection)
DATABASE_URL=postgres://...

# API key for CLI tools (rolls push / rolls backup)
# Must match web_app_api_key in ~/.config/rolls/config.yml
API_KEY=change-me

# Optional: protect the web UI with a password (leave empty to disable)
WEB_PASSWORD=

# Cloudflare R2 for contact sheet storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: public base URL for the R2 bucket (e.g. https://pub-xxx.r2.dev or custom domain).
# If set, contact sheets are stored as direct public URLs instead of routing through the app.
R2_PUBLIC_URL=

# Base URL of this app — used to build absolute contact sheet URLs when R2_PUBLIC_URL is not set.
# Required on Heroku (request.url origin is unreliable behind proxies).
APP_URL=https://rolls.yannick.computer
