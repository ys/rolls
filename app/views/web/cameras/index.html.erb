<div class="page-header">
  <h1 class="page-title">Cameras</h1>
  <%= link_to "New Camera", new_web_camera_path, class: "btn btn-sm" %>
</div>

<% if @cameras.empty? %>
  <div class="empty-state">No cameras yet.</div>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Camera</th>
        <th>Format</th>
        <th>Slug</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @cameras.each do |camera| %>
        <tr>
          <td><%= link_to camera.display_name, web_camera_path(camera) %></td>
          <td><%= camera.format == 135 ? "35mm" : camera.format.to_s + "mm" %></td>
          <td class="text-muted text-xs"><%= camera.slug %></td>
          <td>
            <%= link_to "Edit", edit_web_camera_path(camera), class: "btn btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
