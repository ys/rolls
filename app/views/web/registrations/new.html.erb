<% content_for :head do %>
  <script src="https://appleid.cdn-apple.com/appleauth/static/jsapi/appleid/1/en_US/appleid.auth.js" crossorigin="anonymous"></script>
<% end %>

<div class="auth-hero">
  <div class="auth-wordstack">
    <span class="ws-shoot">shoot</span>
    <span class="ws-develop">develop</span>
    <span class="ws-archive">archive</span>
  </div>
  <div class="auth-appname">Rolls</div>
</div>

<div class="auth-actions">
  <div id="register-error" class="flash flash-alert" style="display:none; margin-bottom:8px; border-radius:4px;"></div>

  <div class="form-group">
    <label class="form-label" for="username">Username</label>
    <input type="text" id="username" class="form-input" placeholder="yourname" autocomplete="username webauthn">
  </div>

  <div class="form-group">
    <label class="form-label" for="invite-code">Invite Code</label>
    <input type="text" id="invite-code" class="form-input" placeholder="Optional">
  </div>

  <button id="register-btn" class="btn-auth-passkey" onclick="registerPasskey()">
    <%= image_tag "person.badge.key.svg", width: 20, height: 20, class: "auth-icon-dark" %>
    Register with Passkey
  </button>

  <button class="btn-auth-apple" onclick="registerWithApple()">
    <svg width="14" height="17" viewBox="0 0 14 17" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M11.76 9.04c-.02-2.1 1.71-3.1 1.79-3.16-.97-1.42-2.49-1.61-3.03-1.64-1.3-.13-2.53.76-3.19.76-.66 0-1.68-.74-2.77-.72C3 4.32 1.68 5.12.96 6.39-.5 8.96.56 12.77 1.98 14.85c.7 1.02 1.53 2.16 2.63 2.12 1.05-.04 1.45-.68 2.72-.68 1.26 0 1.62.68 2.73.66 1.13-.02 1.85-1.03 2.54-2.05.81-1.17 1.14-2.32 1.16-2.38-.03-.01-2.01-.77-2.0-3.08zM9.72 2.76C10.26 2.12 10.63 1.22 10.52.28c-.77.03-1.71.52-2.26 1.15-.49.56-.93 1.47-.81 2.34.86.06 1.73-.43 2.27-1.01z" fill="#f2ede4"/>
    </svg>
    Sign up with Apple
  </button>

  <%= link_to "Already have an account? Sign in", login_path, class: "btn-auth-create" %>
</div>

<script>
async function registerPasskey() {
  const username = document.getElementById('username').value.trim();
  const inviteCode = document.getElementById('invite-code').value.trim();
  const btn = document.getElementById('register-btn');
  const errorEl = document.getElementById('register-error');

  if (!username) {
    showError('Username is required');
    return;
  }

  btn.textContent = 'Registering…';
  btn.disabled = true;
  errorEl.style.display = 'none';

  try {
    const optRes = await fetch('/api/auth/webauthn/register-options', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, invite_code: inviteCode })
    });

    if (!optRes.ok) {
      const err = await optRes.json();
      throw new Error(err.error || 'Failed to get registration options');
    }

    const options = await optRes.json();
    options.challenge = base64urlToBuffer(options.challenge);
    options.user.id = base64urlToBuffer(options.user.id);
    if (options.excludeCredentials) {
      options.excludeCredentials = options.excludeCredentials.map(c => ({
        ...c, id: base64urlToBuffer(c.id)
      }));
    }

    const credential = await navigator.credentials.create({ publicKey: options });
    const credJSON = {
      id: credential.id,
      rawId: bufferToBase64url(credential.rawId),
      type: credential.type,
      response: {
        attestationObject: bufferToBase64url(credential.response.attestationObject),
        clientDataJSON: bufferToBase64url(credential.response.clientDataJSON),
        transports: credential.response.getTransports ? credential.response.getTransports() : []
      }
    };

    const verifyRes = await fetch('/api/auth/webauthn/register-verify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(credJSON)
    });

    const result = await verifyRes.json();
    if (result.success) {
      window.location.href = '/';
    } else {
      throw new Error(result.error || 'Registration failed');
    }
  } catch (err) {
    console.error(err);
    showError(err.message);
    btn.textContent = 'Register with Passkey';
    btn.disabled = false;
  }
}

async function registerWithApple() {
  const username = document.getElementById('username').value.trim();
  const inviteCode = document.getElementById('invite-code').value.trim();
  const errorEl = document.getElementById('register-error');

  if (!username) { showError('Username is required to sign up with Apple'); return; }

  const btn = event.currentTarget;
  btn.disabled = true;
  btn.style.opacity = '0.7';
  errorEl.style.display = 'none';

  try {
    AppleID.auth.init({
      clientId: '<%= ENV["APPLE_SERVICE_ID"] %>',
      scope: 'name email',
      redirectURI: '<%= ENV.fetch("APP_URL", "https://rolls.yannick.computer") %>/auth/apple/callback',
      usePopup: true
    });

    const response = await AppleID.auth.signIn();
    const identityToken = response.authorization.id_token;
    const name = response.user?.name;
    const fullName = name ? [name.firstName, name.lastName].filter(Boolean).join(' ') : null;

    const res = await fetch('/api/auth/apple', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        identity_token: identityToken,
        full_name: fullName,
        username,
        invite_code: inviteCode || undefined
      })
    });
    const data = await res.json();

    if (data.success) {
      window.location.href = '/';
    } else {
      showError(data.error || 'Sign up failed');
      btn.disabled = false;
      btn.style.opacity = '';
    }
  } catch (err) {
    if (!err || err.error !== 'popup_closed_by_user') {
      showError('Apple Sign In failed. Please try again.');
      console.error(err);
    }
    btn.disabled = false;
    btn.style.opacity = '';
  }
}

function showError(msg) {
  const el = document.getElementById('register-error');
  el.textContent = msg;
  el.style.display = 'block';
}

function base64urlToBuffer(base64url) {
  const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
  const bin = atob(base64);
  return Uint8Array.from(bin, c => c.charCodeAt(0)).buffer;
}

function bufferToBase64url(buffer) {
  const bytes = new Uint8Array(buffer);
  let str = '';
  bytes.forEach(b => str += String.fromCharCode(b));
  return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
}
</script>
