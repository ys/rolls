<div class="page-header">
  <h1 class="page-title">New Film</h1>
  <%= link_to "Cancel", web_films_path, class: "btn btn-sm" %>
</div>

<%= form_with model: [:web, @film] do |f| %>
  <div class="form-group">
    <%= f.label :brand, class: "form-label" %>
    <%= f.text_field :brand, class: "form-input", autofocus: true %>
  </div>
  <div class="form-group">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= f.label :nickname, class: "form-label" %>
    <%= f.text_field :nickname, class: "form-input", placeholder: "Optional" %>
  </div>
  <div class="form-group">
    <%= f.label :iso, class: "form-label" %>
    <%= f.number_field :iso, class: "form-input", placeholder: "400" %>
  </div>
  <div class="form-group">
    <%= f.label :color, class: "form-label" %>
    <%= f.check_box :color, class: "form-check", style: "margin-right: 6px;" %>
    <span class="text-sm">Color (vs. B&W)</span>
  </div>
  <div class="form-group">
    <%= f.label :slide, class: "form-label" %>
    <%= f.check_box :slide, class: "form-check", style: "margin-right: 6px;" %>
    <span class="text-sm">Slide film (E-6)</span>
  </div>
  <div class="form-actions">
    <%= f.submit "Add Film", class: "btn btn-primary" %>
  </div>
<% end %>
