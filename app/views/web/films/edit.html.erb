<div class="page-header">
  <h1 class="page-title">Edit Film</h1>
  <%= link_to "Cancel", film_path(@film), class: "btn btn-sm" %>
</div>

<%= form_with model: @film, method: :patch do |f| %>
  <div class="form-group">
    <%= f.label :brand, class: "form-label" %>
    <%= f.text_field :brand, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= f.label :nickname, class: "form-label" %>
    <%= f.text_field :nickname, class: "form-input", placeholder: "Optional" %>
  </div>
  <div class="form-group">
    <%= f.label :iso, class: "form-label" %>
    <%= f.number_field :iso, class: "form-input" %>
  </div>
  <div class="form-group">
    <%= f.check_box :color, style: "margin-right: 6px;" %>
    <%= f.label :color, "Color film", class: "form-label", style: "display:inline;" %>
  </div>
  <div class="form-group">
    <%= f.check_box :slide, style: "margin-right: 6px;" %>
    <%= f.label :slide, "Slide film (E-6)", class: "form-label", style: "display:inline;" %>
  </div>
  <div class="form-actions">
    <%= f.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Cancel", film_path(@film), class: "btn" %>
  </div>
<% end %>
