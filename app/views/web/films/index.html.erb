<div class="page-header">
  <h1 class="page-title">Films</h1>
  <%= link_to "New Film", new_film_path, class: "btn btn-sm" %>
</div>

<% if @films.empty? %>
  <div class="empty-state">No films yet.</div>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Film</th>
        <th>ISO</th>
        <th>Type</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @films.each do |film| %>
        <tr>
          <td>
            <% if film.gradient_from.present? %>
              <span class="film-swatch" style="background: linear-gradient(135deg, <%= film.gradient_from %>, <%= film.gradient_to.presence || film.gradient_from %>);"></span>
            <% end %>
            <%= link_to film.display_name, film_path(film) %>
          </td>
          <td><%= film.iso %></td>
          <td class="text-xs text-muted"><%= film.slide ? "Slide" : (film.color ? "Color" : "B&W") %></td>
          <td>
            <%= link_to "Edit", edit_film_path(film), class: "btn btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
