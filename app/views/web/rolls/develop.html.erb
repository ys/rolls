<div class="page-header">
  <h1 class="page-title">Develop</h1>
  <span class="text-muted text-xs"><%= @rolls.size %> roll<%= @rolls.size == 1 ? "" : "s" %></span>
</div>

<% if @rolls.empty? %>
  <div class="empty-state">No rolls in the develop pipeline.</div>
<% else %>

  <% %w[lab scanned processed uploaded].each do |s| %>
    <% group = @rolls.select { |r| r.status == s } %>
    <% next if group.empty? %>

    <div class="rolls-subsection">
      <div class="rolls-subsection-label"><%= s.capitalize %> — <%= group.size %></div>
      <div class="roll-list">
        <% group.each do |roll| %>
          <%= render "roll_row", roll: roll %>
        <% end %>
      </div>
    </div>
  <% end %>

<% end %>
