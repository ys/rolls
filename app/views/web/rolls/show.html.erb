<% if @roll.status == "archived" %>
  <% content_for :body_class, "archive-body" %>
<% end %>

<%
  back_path = case @roll.status
  when "archived" then archive_path
  when "lab", "scanned", "processed", "uploaded" then develop_path
  else shoot_path
  end
%>

<div class="page-back">
  <%= link_to "← #{back_path == archive_path ? 'Archive' : back_path == develop_path ? 'Develop' : 'Shoot'}", back_path, class: "back-link" %>
</div>

<div class="page-header">
  <h1 class="page-title">
    Roll <%= @roll.roll_number %>
    <%= status_badge(@roll.status) %>
  </h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_roll_path(@roll), class: "btn btn-sm" %>
    <%= button_to "Delete", roll_path(@roll), method: :delete,
        data: { confirm: "Delete this roll?" },
        class: "btn btn-sm btn-danger" %>
  </div>
</div>

<% if @roll.contact_sheet_url.present? %>
  <img src="<%= @roll.contact_sheet_url %>" alt="Contact sheet" class="contact-sheet">
<% end %>

<div class="detail-section">
  <div class="detail-section-title">Equipment</div>
  <div class="detail-grid">
    <span class="detail-label">Camera</span>
    <span class="detail-value">
      <% if @roll.camera %>
        <%= link_to @roll.camera.display_name, camera_path(@roll.camera) %>
      <% else %>
        <span class="text-muted">—</span>
      <% end %>
    </span>
    <span class="detail-label">Film</span>
    <span class="detail-value">
      <% if @roll.film %>
        <%= link_to @roll.film.display_name, film_path(@roll.film) %>
        <% if @roll.film.iso %><span class="text-muted text-xs"> ISO <%= @roll.film.iso %></span><% end %>
      <% else %>
        <span class="text-muted">—</span>
      <% end %>
    </span>
    <% if @roll.push_pull.present? && @roll.push_pull != 0 %>
      <span class="detail-label">Push/Pull</span>
      <span class="detail-value"><%= push_pull_label(@roll.push_pull) %></span>
    <% end %>
  </div>
</div>

<div class="detail-section">
  <div class="detail-section-title">Timeline</div>
  <div class="detail-grid">
    <span class="detail-label">Loaded</span>
    <span class="detail-value"><%= format_datetime(@roll.loaded_at) %></span>
    <span class="detail-label">Shot</span>
    <span class="detail-value"><%= format_date(@roll.shot_at) %></span>
    <span class="detail-label">Fridge</span>
    <span class="detail-value"><%= format_datetime(@roll.fridge_at) %></span>
    <span class="detail-label">Lab sent</span>
    <span class="detail-value">
      <%= format_datetime(@roll.lab_at) %>
      <% if @roll.lab_name.present? %><span class="text-muted text-xs"> · <%= @roll.lab_name %></span><% end %>
    </span>
    <span class="detail-label">Scanned</span>
    <span class="detail-value"><%= format_date(@roll.scanned_at) %></span>
    <span class="detail-label">Processed</span>
    <span class="detail-value"><%= format_datetime(@roll.processed_at) %></span>
    <span class="detail-label">Uploaded</span>
    <span class="detail-value"><%= format_datetime(@roll.uploaded_at) %></span>
    <span class="detail-label">Archived</span>
    <span class="detail-value"><%= format_datetime(@roll.archived_at) %></span>
  </div>
</div>

<% if @roll.album_name.present? || @roll.tags.present? %>
  <div class="detail-section">
    <div class="detail-section-title">Details</div>
    <div class="detail-grid">
      <% if @roll.album_name.present? %>
        <span class="detail-label">Album</span>
        <span class="detail-value"><%= @roll.album_name %></span>
      <% end %>
      <% if @roll.tags.present? %>
        <span class="detail-label">Tags</span>
        <span class="detail-value">
          <div class="roll-tags">
            <% @roll.tags.each do |tag| %>
              <span class="tag"><%= tag %></span>
            <% end %>
          </div>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

<% if @roll.status != "archived" %>
  <div class="notes-editor-section" id="notes-section">
    <div class="detail-section-title">Notes</div>
    <div class="notes-editor-wrap" id="notes-wrap">
      <textarea
        id="notes-field"
        class="notes-editor"
        placeholder="Add notes — location, lighting, experiments…"
        data-roll-id="<%= @roll.uuid %>"
      ><%= @roll.notes %></textarea>
      <div class="notes-editor-status" id="notes-status"></div>
    </div>
  </div>
<% elsif @roll.notes.present? %>
  <div class="detail-section">
    <div class="detail-section-title">Notes</div>
    <div class="detail-value"><%= @roll.notes %></div>
  </div>
<% end %>

<script>
(function() {
  const field = document.getElementById('notes-field');
  if (!field) return;

  const status = document.getElementById('notes-status');
  const rollId = field.dataset.rollId;
  let saveTimer;

  function autoResize() {
    field.style.height = 'auto';
    field.style.height = Math.max(field.scrollHeight, 80) + 'px';
  }

  function saveNotes() {
    status.textContent = 'Saving…';
    fetch('/rolls/' + rollId, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
        'Accept': 'application/json'
      },
      body: JSON.stringify({ roll: { notes: field.value } })
    })
    .then(r => r.ok ? (status.textContent = 'Saved') : Promise.reject())
    .catch(() => { status.textContent = 'Error saving'; })
    .finally(() => { setTimeout(() => { status.textContent = ''; }, 2000); });
  }

  field.addEventListener('input', function() {
    autoResize();
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveNotes, 800);
  });

  field.addEventListener('focus', function() {
    document.getElementById('notes-wrap').classList.add('notes-editor-focused');
  });

  field.addEventListener('blur', function() {
    document.getElementById('notes-wrap').classList.remove('notes-editor-focused');
    clearTimeout(saveTimer);
    if (field.value !== field.defaultValue) saveNotes();
  });

  autoResize();
})();
</script>

<div class="text-muted text-xs mt-4">
  Created <%= format_datetime(@roll.created_at) %> ·
  Updated <%= format_datetime(@roll.updated_at) %>
</div>
