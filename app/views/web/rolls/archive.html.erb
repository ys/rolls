<% content_for :body_class, "archive-body" %>

<% if @rolls.empty? %>
  <div class="empty-state" style="color:rgba(245,240,232,0.3);">No archived rolls yet.</div>
<% else %>
  <% years_data = @rolls.group_by { |r| r.roll_number.to_s[0, 2] } %>

  <div class="archive-year-pills">
    <button class="archive-year-pill active" data-year="all" onclick="filterYear('all', this)">All</button>
    <% years_data.each_key do |yy| %>
      <button class="archive-year-pill" data-year="<%= yy %>" onclick="filterYear('<%= yy %>', this)">20<%= yy %></button>
    <% end %>
  </div>

  <% years_data.each do |yy, rolls| %>
    <% year = yy.present? ? "20#{yy}" : "—" %>
    <div class="archive-year-section" data-year="<%= yy %>">
      <div class="archive-year-label"><%= year %></div>
      <div class="archive-grid">
        <% rolls.each do |roll| %>
          <%= link_to roll_path(roll), class: "archive-card" do %>
            <div class="archive-card-info">
              <div class="archive-card-info-left">
                <span class="archive-card-film"><%= roll.film&.display_name || "—" %></span>
                <span class="archive-card-meta">
                  <%
                    parts = []
                    parts << roll.camera.display_name if roll.camera
                    parts << "#{roll.camera.format}mm" if roll.camera&.format&.positive?
                  %>
                  <%= parts.join(" · ") %>
                </span>
              </div>
              <div class="archive-card-info-right">
                <span class="archive-card-number"><%= roll.roll_number %></span>
                <span class="archive-card-date">
                  <%= roll.archived_at&.strftime("%b %Y") %>
                  <% if roll.album_name.present? %> · <%= roll.album_name %><% end %>
                </span>
              </div>
            </div>
            <div class="archive-card-image">
              <% if roll.contact_sheet_url.present? %>
                <img src="<%= roll.contact_sheet_url %>" alt="" />
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<script>
function filterYear(yy, btn) {
  document.querySelectorAll('.archive-year-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.archive-year-section').forEach(s => {
    s.style.display = (yy === 'all' || s.dataset.year === yy) ? '' : 'none';
  });
}
</script>
