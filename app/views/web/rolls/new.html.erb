<div class="new-roll-header">
  <div class="new-roll-number"><%= @next_number %></div>
  <div class="new-roll-number-label">next roll</div>
</div>

<%= form_with model: @roll, url: rolls_path, method: :post do |f| %>
  <div class="detail-section">
    <div class="detail-section-title">Equipment</div>

    <div class="form-group">
      <%= f.label :film_uuid, "Film", class: "form-label" %>
      <%= f.select :film_uuid,
            [["— select film —", nil]] + @films.map { |film| [film.display_name, film.uuid] },
            { selected: nil },
            class: "form-select" %>
    </div>

    <div class="form-group">
      <div class="form-label-row">
        <%= f.label :camera_uuid, "Camera", class: "form-label" %>
        <span class="form-label-optional">optional</span>
      </div>
      <%= f.select :camera_uuid,
            [["No camera yet", nil]] + @cameras.map { |c| [c.display_name, c.uuid] },
            { selected: nil },
            class: "form-select" %>
      <div class="form-hint">
        <span class="form-hint-dot fridge"></span>
        Without a camera the roll goes to your fridge — track it until you load it.
      </div>
    </div>
  </div>

  <div class="detail-section">
    <div class="detail-section-title">Details</div>

    <div class="form-group">
      <div class="form-label-row">
        <%= f.label :album_name, "Album name", class: "form-label" %>
        <span class="form-label-optional">optional</span>
      </div>
      <%= f.text_field :album_name, class: "form-input", placeholder: "e.g. Summer 2026, Brittany trip…" %>
    </div>

    <%= f.hidden_field :roll_number, value: "" %>
  </div>

  <div class="form-actions">
    <%= f.submit "Start Roll", class: "btn btn-primary" %>
    <%= link_to "Cancel", root_path, class: "btn" %>
  </div>
<% end %>
