<% content_for :head do %>
  <script src="https://appleid.cdn-apple.com/appleauth/static/jsapi/appleid/1/en_US/appleid.auth.js" crossorigin="anonymous"></script>
<% end %>

<div class="auth-hero">
  <div class="auth-wordstack">
    <span class="ws-shoot">shoot</span>
    <span class="ws-develop">develop</span>
    <span class="ws-archive">archive</span>
  </div>
  <div class="auth-appname">Rolls</div>
</div>

<div class="auth-actions">
  <% if flash[:alert] %>
    <div class="flash flash-alert" style="margin-bottom:8px;border-radius:4px;"><%= flash[:alert] %></div>
  <% end %>

  <button id="passkey-btn" class="btn-auth-apple" onclick="signInWithApple()">
    <svg width="14" height="17" viewBox="0 0 14 17" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M11.76 9.04c-.02-2.1 1.71-3.1 1.79-3.16-.97-1.42-2.49-1.61-3.03-1.64-1.3-.13-2.53.76-3.19.76-.66 0-1.68-.74-2.77-.72C3 4.32 1.68 5.12.96 6.39-.5 8.96.56 12.77 1.98 14.85c.7 1.02 1.53 2.16 2.63 2.12 1.05-.04 1.45-.68 2.72-.68 1.26 0 1.62.68 2.73.66 1.13-.02 1.85-1.03 2.54-2.05.81-1.17 1.14-2.32 1.16-2.38-.03-.01-2.01-.77-2.0-3.08zM9.72 2.76C10.26 2.12 10.63 1.22 10.52.28c-.77.03-1.71.52-2.26 1.15-.49.56-.93 1.47-.81 2.34.86.06 1.73-.43 2.27-1.01z" fill="#f2ede4"/>
    </svg>
    Sign in with Apple
  </button>

  <button id="passkey-btn" class="btn-auth-passkey" onclick="signInWithPasskey()">
    <%= image_tag "person.badge.key.svg", width: 20, height: 20, class: "auth-icon-dark" %>
    Sign in with Passkey
  </button>

  <%= link_to "Create account", register_path, class: "btn-auth-create" %>
</div>

<div id="apple-new-account" style="display:none; margin-top:12px;">
  <div class="flash flash-alert" id="apple-account-error" style="display:none; margin-bottom:8px; border-radius:4px;"></div>
  <p class="text-sm text-muted" style="margin-bottom:12px;">No account found for your Apple ID. Choose a username to create one.</p>
  <div class="form-group">
    <label class="form-label" for="apple-username">Username</label>
    <input type="text" id="apple-username" class="form-input" placeholder="yourname" autocomplete="username">
  </div>
  <div class="form-group">
    <label class="form-label" for="apple-invite-code">Invite Code</label>
    <input type="text" id="apple-invite-code" class="form-input" placeholder="Optional">
  </div>
  <button class="btn-auth-passkey" onclick="submitAppleNewAccount()">Create account</button>
  <button class="btn-auth-create" onclick="cancelAppleNewAccount()" style="margin-top:8px;">Cancel</button>
</div>

<script>
let _appleToken = null;
let _appleFullName = null;

async function signInWithApple() {
  const btn = document.querySelector('.btn-auth-apple');
  btn.disabled = true;
  btn.style.opacity = '0.7';

  try {
    AppleID.auth.init({
      clientId: '<%= ENV["APPLE_SERVICE_ID"] %>',
      scope: 'name email',
      redirectURI: '<%= ENV.fetch("APP_URL", "https://rolls.yannick.computer") %>/auth/apple/callback',
      usePopup: true
    });

    const response = await AppleID.auth.signIn();
    const identityToken = response.authorization.id_token;
    const name = response.user?.name;
    const fullName = name ? [name.firstName, name.lastName].filter(Boolean).join(' ') : null;

    await handleAppleToken(identityToken, fullName, btn);
  } catch (err) {
    if (!err || err.error !== 'popup_closed_by_user') {
      console.error(err);
      alert('Apple Sign In failed. Please try again.');
    }
    btn.disabled = false;
    btn.style.opacity = '';
  }
}

async function handleAppleToken(identityToken, fullName, btn) {
  const res = await fetch('/api/auth/apple', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ identity_token: identityToken, full_name: fullName })
  });
  const data = await res.json();

  if (data.success) {
    window.location.href = '/';
    return;
  }

  if (data.error === 'new_account_required') {
    _appleToken = identityToken;
    _appleFullName = fullName;
    document.getElementById('apple-new-account').style.display = 'block';
    document.querySelector('.auth-actions').querySelectorAll('button, a').forEach(el => {
      if (!el.closest('#apple-new-account')) el.style.display = 'none';
    });
    return;
  }

  alert(data.error || 'Sign in failed');
  if (btn) { btn.disabled = false; btn.style.opacity = ''; }
}

async function submitAppleNewAccount() {
  const username = document.getElementById('apple-username').value.trim();
  const inviteCode = document.getElementById('apple-invite-code').value.trim();
  const errorEl = document.getElementById('apple-account-error');

  if (!username) { errorEl.textContent = 'Username is required'; errorEl.style.display = 'block'; return; }

  const res = await fetch('/api/auth/apple', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      identity_token: _appleToken,
      full_name: _appleFullName,
      username,
      invite_code: inviteCode || undefined
    })
  });
  const data = await res.json();

  if (data.success) {
    window.location.href = '/';
  } else {
    errorEl.textContent = data.error || 'Account creation failed';
    errorEl.style.display = 'block';
  }
}

function cancelAppleNewAccount() {
  _appleToken = null;
  _appleFullName = null;
  document.getElementById('apple-new-account').style.display = 'none';
  document.getElementById('apple-account-error').style.display = 'none';
  document.querySelector('.auth-actions').querySelectorAll('button, a').forEach(el => el.style.display = '');
}

async function signInWithPasskey() {
  const btn = document.getElementById('passkey-btn');
  btn.textContent = 'Authenticating…';
  btn.disabled = true;

  try {
    const optRes = await fetch('/api/auth/webauthn/login-options', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({})
    });
    const options = await optRes.json();

    options.challenge = base64urlToBuffer(options.challenge);
    if (options.allowCredentials) {
      options.allowCredentials = options.allowCredentials.map(c => ({
        ...c, id: base64urlToBuffer(c.id)
      }));
    }

    const credential = await navigator.credentials.get({ publicKey: options });
    const credJSON = {
      id: credential.id,
      rawId: bufferToBase64url(credential.rawId),
      type: credential.type,
      response: {
        authenticatorData: bufferToBase64url(credential.response.authenticatorData),
        clientDataJSON: bufferToBase64url(credential.response.clientDataJSON),
        signature: bufferToBase64url(credential.response.signature),
        userHandle: credential.response.userHandle ? bufferToBase64url(credential.response.userHandle) : null
      }
    };

    const verifyRes = await fetch('/api/auth/webauthn/login-verify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(credJSON)
    });
    const result = await verifyRes.json();

    if (result.success) {
      window.location.href = '/';
    } else {
      alert(result.error || 'Authentication failed');
      btn.textContent = 'Sign in with Passkey';
      btn.disabled = false;
    }
  } catch (err) {
    console.error(err);
    alert('Passkey sign-in failed: ' + err.message);
    btn.textContent = 'Sign in with Passkey';
    btn.disabled = false;
  }
}

function base64urlToBuffer(base64url) {
  const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
  const bin = atob(base64);
  return Uint8Array.from(bin, c => c.charCodeAt(0)).buffer;
}

function bufferToBase64url(buffer) {
  const bytes = new Uint8Array(buffer);
  let str = '';
  bytes.forEach(b => str += String.fromCharCode(b));
  return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
}
</script>
